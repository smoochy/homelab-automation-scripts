# Shared configuration for monitor_sab_speed.sh and monitor_sab_speed_kuma.sh
# Edit this file on the host as .env. The scripts should normally not need edits.

# SABnzbd host and API settings
APPDATA_ROOT="/mnt/user/appdata" # Base appdata directory on the host.
SAB_APPDATA_DIR="/mnt/user/appdata/sabnzbd" # SABnzbd appdata directory containing sabnzbd.ini.
SAB_HOST="127.0.0.1" # Hostname or IP where the SABnzbd API is reachable.
SAB_PORT="8082" # Host port that exposes the SABnzbd web/API interface.
SAB_URL_BASE="/sabnzbd" # SABnzbd URL base path.

# Speed monitor behavior
AVERAGE_WINDOW_MINUTES="2" # Average download speed over this many minutes.
SPEED_THRESHOLD_MBPS="10" # Restart threshold in MB/s for the sampled average speed.
COOLDOWN_MINUTES="1" # Minimum minutes between two recovery actions.
LOG_RESET_DAYS="1" # Clear the logfile after this many days. Set to 0 to disable.
VERBOSE_OUTPUT="1" # Set to 1 to write to the logfile and print to stdout; 0 writes only to the logfile.
ENABLE_RECOVERY="1" # Set to 0 for dry-run mode without restart actions.
WAIT_FOR_SAB_SECONDS="120" # Max seconds to wait until SABnzbd responds again.

# Recovery mode
# Supported values: komodo_stack, komodo_split_stacks, komodo_procedure, docker
RECOVERY_METHOD="komodo_stack" # Recovery mode: komodo_stack, komodo_split_stacks, komodo_procedure, or docker.
KOMODO_STACK_NAME="sabnzbd" # Komodo stack name when gluetun and SABnzbd are in one stack.
GLUETUN_STACK_NAME="gluetun" # Komodo gluetun stack name for split-stack recovery.
SAB_STACK_NAME="sabnzbd" # Komodo sabnzbd stack name for split-stack recovery.
KOMODO_PROCEDURE_NAME="" # Optional Komodo procedure name when using komodo_procedure.
KOMODO_CORE_NAME="komodo-core" # Komodo core container name used for km execute.
KOMODO_CLI_KEY="" # Komodo CLI key required for authenticated km execute calls.
KOMODO_CLI_SECRET="" # Komodo CLI secret required for authenticated km execute calls.
WAIT_AFTER_GLUETUN_SECONDS="20" # Delay after gluetun restart in split recovery modes.
GLUETUN_CONTAINER="gluetun" # Gluetun container name for docker recovery mode.
SAB_CONTAINER="sabnzbd" # SABnzbd container name for docker recovery mode.

# Uptime Kuma integration
ENABLE_KUMA_MAINTENANCE="1" # Set to 1 to call the Kuma helper around recovery.
KUMA_CONTAINER_NAME="uptime-kuma" # Uptime Kuma container name for docker exec based control.
KUMA_BASE_URL="http://127.0.0.1:3001" # Uptime Kuma URL as seen from inside the container.
KUMA_DB_FILE="/mnt/user/appdata/uptimekuma/kuma.db" # Host path to kuma.db for maintenance lookup.
KUMA_DEFAULT_MAINTENANCE_ID="" # Optional existing dedicated manual maintenance ID to toggle.
KUMA_DEFAULT_MAINTENANCE_TITLE="SABnzbd Recovery" # Auto-created manual maintenance title when no ID is set.
KUMA_DEFAULT_MAINTENANCE_DESCRIPTION="Triggered by monitor_sab_speed.sh during SABnzbd recovery." # Description for auto-created maintenance.
KUMA_DEFAULT_MONITOR_IDS="28,41" # Comma-separated monitor IDs for the dedicated maintenance.
KUMA_SOCKET_TIMEOUT_MS="20000" # Timeout in milliseconds for Kuma socket connect/login/action acks.
KUMA_SOCKET_RETRIES="3" # Number of attempts for Kuma socket actions before failing.
KUMA_SOCKET_RETRY_SLEEP_SECONDS="2" # Seconds to wait between Kuma socket retries.

# Uptime Kuma credentials
# Use either KUMA_AUTH_TOKEN or KUMA_USERNAME plus KUMA_PASSWORD.
# Leave unused values empty.
KUMA_AUTH_TOKEN="" # Preferred auth method when available.
KUMA_USERNAME="" # Kuma username when not using an auth token.
KUMA_PASSWORD="" # Kuma password when not using an auth token.

# Optional test flags
FORCE_LOW_SPEED_TEST="0" # Set to 1 to force the low-speed branch for testing.
FORCE_LOW_SPEED_MBPS="0.50" # Forced average in MB/s used when the low-speed test is active.
IGNORE_COOLDOWN_FOR_TEST="0" # Set to 1 to bypass cooldown during forced test runs.
