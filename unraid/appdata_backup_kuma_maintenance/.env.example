# Local configuration for the appdata backup Uptime Kuma helper.
# Copy this file to `.env` on the host and adapt the values for your environment.

# Base paths
APPDATA_ROOT="/mnt/user/appdata" # Base appdata directory on the host.
KUMA_DB_FILE="/mnt/user/appdata/uptimekuma/kuma.db" # Host path to kuma.db, used for maintenance lookup and active-state checks.

# Uptime Kuma connection
KUMA_CONTAINER_NAME="uptime-kuma" # Uptime Kuma container name for docker-exec based control.
KUMA_BASE_URL="http://127.0.0.1:3001" # Uptime Kuma URL as seen from inside the container.

# Maintenance defaults
KUMA_DEFAULT_MAINTENANCE_ID="" # Optional existing dedicated manual maintenance ID to reuse.
KUMA_DEFAULT_MAINTENANCE_TITLE="Appdata Backup" # Auto-created manual maintenance title when no ID is set.
KUMA_DEFAULT_MAINTENANCE_DESCRIPTION="Triggered by the appdata.backup pre-run/post-run hooks while Docker containers are stopped." # Description for the dedicated maintenance.
KUMA_INCLUDE_INACTIVE_MONITORS="0" # Set to 1 to include inactive monitors in the maintenance; 0 limits it to active monitors only.
KUMA_POST_RUN_TIMEOUT_SECONDS="600" # Maximum total wait time after backup until remaining monitors stay in maintenance.
KUMA_POST_RUN_POLL_INTERVAL_SECONDS="5" # Seconds between readiness checks during the post-run phase.
KUMA_POST_RUN_HTTP_TIMEOUT_SECONDS="10" # Timeout per HTTP domain check while waiting for HTTP monitors to recover.
KUMA_POST_RUN_CURL_INSECURE="0" # Set to 1 only if HTTP checks must ignore TLS verification during routing or certificate warmup.
KUMA_HTTP_MONITOR_ALIAS_MAP='{}' # Optional JSON map for host aliases when Kuma URL hosts differ from the externally checked hosts.

# Logging and retry behavior
LOG_RESET_DAYS="7" # Clear the logfile after this many days. Set to 0 to disable.
VERBOSE_OUTPUT="1" # 0 writes only to the logfile, 1 prints normal progress, 2 also prints detailed mapping/debug lines.
KUMA_SOCKET_TIMEOUT_MS="20000" # Timeout in milliseconds for Kuma socket connect/login/action acks.
KUMA_SOCKET_RETRIES="5" # Number of attempts for Kuma socket actions before failing.
KUMA_SOCKET_RETRY_SLEEP_SECONDS="2" # Seconds to wait between Kuma socket retries.

# Uptime Kuma credentials
# Use either KUMA_AUTH_TOKEN or KUMA_USERNAME plus KUMA_PASSWORD.
# Leave unused values empty.
KUMA_AUTH_TOKEN="" # Preferred auth method when available.
KUMA_USERNAME="" # Kuma username when not using an auth token.
KUMA_PASSWORD="" # Kuma password when not using an auth token.
